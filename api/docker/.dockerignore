# API Diet - Docker build ignore file
# Optimize build context by excluding unnecessary files

# Version control
.git/
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
.python-version

# Testing and coverage
.coverage
.coverage.*
.pytest_cache/
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Development tools
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Documentation
docs/
*.md
!README.md

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore

# Build artifacts
build/
dist/
*.egg-info/

# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Temporary files
tmp/
temp/
*.tmp

# Node.js (if any frontend assets)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backup files
*.bak
*.backup

# Database files
*.db
*.sqlite
*.sqlite3

# Media files (usually not needed in container)
media/
static/uploads/

# Test fixtures
tests/fixtures/test_files/

# Local development scripts
scripts/dev-*
scripts/local-*

# Fly.io specific
fly.toml
fly.*.toml
.fly/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Kubernetes
k8s/
kubernetes/

# Helm
helm/

# Monitoring and profiling
.profile
*.prof