# ===========================================
# DietLogo AI — Environment Variables
# ===========================================
# Copy this file to .env.dev (or .env.prod) and fill in real values.
# NEVER commit .env.dev or .env.prod to version control.

# --- Application ---
ENVIRONMENT=development          # development | production
DEBUG=true                       # Enable debug mode

# --- Supabase (Database + Auth) ---
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=your-supabase-publishable-key

# --- Authentication ---
DEV_AUTH_BYPASS=false             # Set true to skip auth in development

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379/0

# --- Email (optional) ---
SEND_GRID=your-sendgrid-api-key

# --- Swagger UI Protection ---
SWAGGER_USER=admin
SWAGGER_PASS=changeme

# --- CORS ---
CORS_ORIGINS=http://localhost:4200,http://localhost:4300

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100          # Max requests per window
RATE_LIMIT_WINDOW=60             # Window in seconds

# --- Logging ---
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                  # json | text

# --- Monitoring ---
ENABLE_METRICS=true

# --- Performance ---
CONNECTION_TIMEOUT=10            # HTTP connection timeout (seconds)
READ_TIMEOUT=30                  # HTTP read timeout (seconds)

# --- Database Pool ---
DATABASE_POOL_SIZE=15
DATABASE_MAX_OVERFLOW=3
DATABASE_POOL_TIMEOUT=10
DATABASE_POOL_RECYCLE=300
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false
DATABASE_COMMAND_TIMEOUT=30

# --- Cache TTLs (seconds) ---
CACHE_TTL_DEFAULT=300
CACHE_TTL_USERS=600
CACHE_TTL_LEAGUES=1800

# --- Encryption (BYOK) ---
# 32-byte base64-encoded key for AES-256-GCM API key encryption
# Generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
API_KEY_ENCRYPTION_SECRET=

# --- AI / LLM ---
# In production, each user brings their own key (BYOK).
# These fallback keys are only used for admin/testing when no user key is stored.
OPENAI_API_KEY=              # Optional — fallback for admin/testing only
GOOGLE_API_KEY=              # Optional — fallback for admin/testing only
ANTHROPIC_API_KEY=           # Optional — fallback for admin/testing only
